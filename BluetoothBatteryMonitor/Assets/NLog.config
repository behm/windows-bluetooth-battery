<?xml version="1.0" encoding="utf-8" ?>
<!-- NLog configuration file.
     This file is a fallback/override for programmatic setup in LoggingSetup.cs.
     It is copied to the output directory and loaded automatically if present. -->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off">

  <targets>
    <target xsi:type="Null" name="blackhole" />
  </targets>

  <rules>
    <!-- All rules are configured programmatically in LoggingSetup.cs -->
    <logger name="*" minlevel="Off" writeTo="blackhole" />
  </rules>
</nlog>
