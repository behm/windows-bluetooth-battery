<Window x:Class="BluetoothBatteryMonitor.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bluetooth Battery Monitor — Settings"
        Width="420" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#F3F3F3">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="DescriptionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <!-- Refresh Interval -->
            <TextBlock Style="{StaticResource SectionLabel}" Text="Refresh Interval"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="RefreshSlider"
                        Grid.Column="0"
                        Minimum="60" Maximum="600" TickFrequency="60"
                        IsSnapToTickEnabled="True"
                        ValueChanged="RefreshSlider_ValueChanged"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="RefreshValueLabel"
                           Grid.Column="1"
                           Text="5 min"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="8,0,0,0"/>
            </Grid>
            <TextBlock Style="{StaticResource DescriptionLabel}"
                       Text="How often to query device battery levels (1–10 minutes)."/>

            <!-- Low Battery Warning Threshold -->
            <TextBlock Style="{StaticResource SectionLabel}" Text="Low Battery Warning Threshold"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="ThresholdSlider"
                        Grid.Column="0"
                        Minimum="5" Maximum="50" TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        ValueChanged="ThresholdSlider_ValueChanged"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ThresholdValueLabel"
                           Grid.Column="1"
                           Text="20%"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="8,0,0,0"/>
            </Grid>
            <TextBlock Style="{StaticResource DescriptionLabel}"
                       Text="Show a notification when a device battery falls below this percentage."/>

            <!-- Log Level -->
            <TextBlock Style="{StaticResource SectionLabel}" Text="Log Level"/>
            <ComboBox x:Name="LogLevelCombo"
                      Width="140" HorizontalAlignment="Left">
                <ComboBoxItem Content="Trace"/>
                <ComboBoxItem Content="Debug"/>
                <ComboBoxItem Content="Info"/>
                <ComboBoxItem Content="Warn"/>
                <ComboBoxItem Content="Error"/>
                <ComboBoxItem Content="Off"/>
            </ComboBox>
            <TextBlock Style="{StaticResource DescriptionLabel}"
                       Text="Verbosity of the log file. Changes apply on next launch."/>

            <!-- Auto-Start -->
            <CheckBox x:Name="AutoStartCheckBox"
                      Margin="0,16,0,0"
                      Content="Launch automatically when Windows starts"/>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Save"
                    Width="80" Height="28"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
            <Button Content="Cancel"
                    Width="80" Height="28"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
